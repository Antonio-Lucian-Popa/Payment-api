# Variabile de mediu - Copiează acest fișier în .env și completează cu valorile tale

# Stripe Keys
# Obții aceste chei din Stripe Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration (domenii autorizate)
# Separă cu virgulă dacă sunt mai multe: http://localhost:3000,https://app.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
